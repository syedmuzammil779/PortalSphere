<!-- HTML Form Structure -->
<div id="wholesalerRegistrationPopup" style="width: 100%; height: 100%; background-color: white; display: flex; justify-content: center; align-items: center; z-index: 1000;">
<form id="wholesalerRegistrationForm" style="background-color: white; padding: 20px; border-radius: 8px; width: 100%;">               
    <label for="employeeTaxID">Employee Tax ID</label>
    <input type="text" id="employeeTaxID" name="employeeTaxID" required style="width: 100%; padding: 8px; margin: 8px 0; display: block; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;">
    
    <label for="companyName">Company Name</label>
    <input type="text" id="companyName" name="companyName" required style="width: 100%; padding: 8px; margin: 8px 0; display: block; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;">
    
    <label for="companyAddress">Company Address</label>
    <input type="text" id="companyAddress" name="companyAddress" required style="width: 100%; padding: 8px; margin: 8px 0; display: block; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;">
    
    <label for="contactFirstName">Contact First Name</label>
    <input type="text" id="contactFirstName" name="contactFirstName" required style="width: 100%; padding: 8px; margin: 8px 0; display: block; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;">
    
    <label for="contactLastName">Contact Last Name</label>
    <input type="text" id="contactLastName" name="contactLastName" required style="width: 100%; padding: 8px; margin: 8px 0; display: block; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;">
    
    <label for="emailAddress">Email Address</label>
    <input type="email" id="emailAddress" name="emailAddress" required style="width: 100%; padding: 8px; margin: 8px 0; display: block; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;">
    
    <label for="phoneNumber">Phone Number</label>
    <input type="tel" id="phoneNumber" name="phoneNumber" placeholder="123-456-7890" required style="width: 100%; padding: 8px; margin: 8px 0; display: block; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;">
    
    <label for="buyerType">Buyer Type</label>
    <select id="buyerType" name="buyerType" required style="width: 100%; padding: 8px; margin: 8px 0; display: block; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;">
    <option value="Retailer">Retailer</option>
    <option value="Wholesaler">Wholesaler</option>
    <option value="Distributor">Distributor</option>
    </select>
    
    <label for="locationsOwned">Locations Owned/Serviced</label>
    <input type="number" id="locationsOwned" name="locationsOwned" min="1" required style="width: 100%; padding: 8px; margin: 8px 0; display: block; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;">
    
    <button type="submit" style="background-color: #000; color: #fff; border: none; padding: 10px 20px; font-size: 14px; font-weight: bold; width: 100%; cursor: pointer; margin-bottom: 10px;">Save</button>
    <button type="button" id="closePopup" style="background-color: #fff; color: #000; border: none; padding: 10px 20px; font-size: 14px; font-weight: bold; width: 100%; cursor: pointer; margin-bottom: 10px;">Close</button>
</form>
</div>

<script>
//console.debug('Wholesaler Registration Form 202411280132');
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('wholesalerRegistrationForm');
    const closeButton = document.getElementById('closePopup');
    const locationsOwnedInput = document.getElementById('locationsOwned');
    const phoneInput = document.getElementById('phoneNumber');

    function showToast(message, duration = 3000) {
        const toast = document.createElement('div');
        toast.textContent = message;
        toast.style.cssText = `
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background-color: #333;
            color: white;
            padding: 10px 20px;
            border-radius: 5px;
            z-index: 1001;
        `;
        document.body.appendChild(toast);
        setTimeout(() => {
            document.body.removeChild(toast);
        }, duration);
    }

    locationsOwnedInput.addEventListener('input', function() {
        if (this.value <= 0) {
            this.setCustomValidity('Number of locations must be greater than 0');
        } else {
            this.setCustomValidity('');
        }
    });

    phoneInput.addEventListener('input', function(e) {
        const x = e.target.value.replace(/\\D/g, '').match(/(\\d{0,3})(\\d{0,3})(\\d{0,4})/);
        e.target.value = !x[2] ? x[1] : '(' + x[1] + ') ' + x[2] + (x[3] ? '-' + x[3] : '');
    });

    phoneInput.addEventListener('blur', function() {
        const phoneNumber = this.value.replace(/\\D/g, '');
        if (phoneNumber.length !== 10) {
            this.setCustomValidity('Please enter a valid 10-digit phone number');
        } else {
            this.setCustomValidity('');
        }
    });

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        if (parseInt(locationsOwnedInput.value, 10) <= 0) {
            showToast('Number of locations must be greater than 0', 3000);
            return;
        }

        const phoneNumber = phoneInput.value.replace(/\\D/g, '');
        if (phoneNumber.length !== 10) {
            showToast('Please enter a valid 10-digit phone number', 3000);
            return;
        }

        const formData = new FormData(form);
        const requestBody = {
            shop: `{{shop}}`,
            api_key: `{{SHOPIFY_API_KEY}}`,
            timestamp: `{{timestamp}}`,
            hmac: `{{hmac}}`,
            companyName: formData.get('companyName'),
            companyAddress: formData.get('companyAddress'),
            contactFirstName: formData.get('contactFirstName'),
            contactLastName: formData.get('contactLastName'),
            emailAddress: formData.get('emailAddress'),
            phoneNumber: formData.get('phoneNumber'),
            buyerType: formData.get('buyerType'),
            locationCount: formData.get('locationsOwned'),
            employee_tax_id: formData.get('employeeTaxID')
        };

        try {
            const response = await fetch(`https://{{requestUrl}}/api/wholesalepricingform`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify(requestBody)
            });

            const result = await response.json();

            if (response.ok) {
                showToast('Form submitted successfully. Waiting for approval.', 5000);
            } else {
                if (result.errors && Array.isArray(result.errors)) {
                    showToast('Errors: ' + result.errors.join(', '), 5000);
                } else if (result.error) {
                    showToast('Error: ' + result.error, 5000);
                } else {
                    showToast('An unknown error occurred', 5000);
                }
            }
        } catch (error) {
            console.error('Error:', error);
            showToast('An error occurred while submitting the form.', 5000);
        }
    });
});
</script>